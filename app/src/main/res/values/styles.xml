<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.GarbageCollection.SurfaceCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/surface_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.GarbageCollection.FloatingCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">26dp</item>
        <item name="cardElevation">10dp</item>
        <item name="strokeColor">@color/surface_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.GarbageCollection.PrimaryFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/brand_forest</item>
        <item name="rippleColor">@color/surface_background_alt</item>
    </style>

    <style name="Widget.GarbageCollection.AccentFab" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/brand_sun</item>
        <item name="rippleColor">@color/surface_background_alt</item>
    </style>
</resources>
