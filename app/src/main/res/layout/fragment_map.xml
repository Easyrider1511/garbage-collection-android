<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/title_map" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMapFilter"
        style="@style/Widget.GarbageCollection.FloatingCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvMapFilterLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_map_filter"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerCollectionTypeFilter"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

            <TextView
                android:id="@+id/tvMapFilterSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/map_filter_summary_zero"
                android:textColor="@color/brand_forest"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMapZoom"
        style="@style/Widget.GarbageCollection.FloatingCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMapZoomIn"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/action_map_zoom_in"
                android:minWidth="0dp"
                android:text="@string/map_zoom_in_symbol"
                android:textColor="@color/brand_forest"
                android:textSize="24sp"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMapZoomOut"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="4dp"
                android:contentDescription="@string/action_map_zoom_out"
                android:minWidth="0dp"
                android:text="@string/map_zoom_out_symbol"
                android:textColor="@color/brand_forest"
                android:textSize="24sp"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/mapMessageContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvMapMessageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/map_unavailable_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMapMessageBody"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/map_load_fallback_message"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />
    </LinearLayout>
</FrameLayout>
